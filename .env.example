VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase service_role key (NUNCA expor no frontend - sem prefixo VITE_)
# Obtenha em: Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=

# Sync VIOS → Supabase (script vios:baixar-e-sync ou sync:vios)
# VIOS_REPORT_PATH=C:/Users/bp01/OneDrive - BPPLAW/.../Processos Completo.xlsx
# VIOS_USER=seu_email@bismarchipires.com.br
# VIOS_PASS=sua_senha
# VIOS_HEADLESS=true   (opcional: rodar browser em segundo plano)
